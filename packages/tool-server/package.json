{
  "name": "@kontext-brain/tool-server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kontext-tool-server": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@kontext-brain/core": "workspace:*",
    "@kontext-brain/loader": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.24.1"
  }
}
